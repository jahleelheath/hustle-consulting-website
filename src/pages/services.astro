---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: '01',
    title: 'Business Consulting',
    tagline: 'Strategy built for where you actually are.',
    desc: 'We work with local and small business owners to build clear growth strategy. No generic frameworks — we diagnose your specific situation, identify your highest-leverage opportunities, and build a roadmap you can actually execute.',
    bullets: [
      'Business audit & opportunity analysis',
      'Growth strategy & roadmap',
      'AI tool identification for your workflow',
      'Ongoing advisory support',
    ],
  },
  {
    num: '02',
    title: 'AI Strategy',
    tagline: 'AI for your business — practical, not theoretical.',
    desc: 'We identify which AI tools actually fit your operation and implement them in a way your team will use. Not a pitch deck about the future of AI — a real plan for what you can use today to save time and grow faster.',
    bullets: [
      'AI readiness assessment',
      'Tool selection & integration roadmap',
      'Workflow automation design',
      'Team training & adoption support',
    ],
  },
  {
    num: '03',
    title: 'App Development',
    tagline: 'Custom software built to your spec.',
    desc: 'From idea to live product. We build custom mobile and web applications for businesses that need software that doesn\'t exist yet — or that need to replace something that stopped working.',
    bullets: [
      'Full-stack web & mobile apps',
      'Product scoping & MVP definition',
      'API integrations',
      'Ongoing maintenance & iteration',
    ],
  },
  {
    num: '04',
    title: 'Web Development',
    tagline: 'Sites that convert, not just look good.',
    desc: 'Professional business websites built to drive the action you want — a call, a form fill, a purchase. Fast, SEO-optimized, and built to represent your brand the right way from day one.',
    bullets: [
      'Marketing & business sites',
      'Landing pages & lead capture',
      'SEO & performance optimization',
      'Domain, hosting & deployment',
    ],
  },
];
---
<BaseLayout title="Services — H.U.S.T.L.E Consulting LLC">
  <Nav />
  <main>
    <!-- Page hero -->
    <div class="pt-36 pb-16 px-6 md:px-12 max-w-[1300px] mx-auto">
      <div class="flex items-center gap-3 mb-6 reveal">
        <div class="w-6 h-px bg-[var(--red)]"></div>
        <span class="text-[9px] font-black tracking-[5px] uppercase text-[var(--red)]">What We Do</span>
      </div>
      <h1 class="font-black uppercase leading-[0.85] reveal reveal-delay-1" style="font-size: clamp(48px, 9vw, 110px); letter-spacing: -3px;">
        Our<br>
        <span class="text-[var(--red)]">Services</span>
      </h1>
    </div>

    <!-- Services list -->
    <div class="px-6 md:px-12 max-w-[1300px] mx-auto pb-24" style="border-top: 1px solid var(--border-red);">
      <div class="flex flex-col">
        {services.map((s, i) => (
          <div class={`reveal reveal-delay-${i + 1} grid grid-cols-1 md:grid-cols-[80px_1fr] gap-8 md:gap-16 py-16`} style="border-bottom: 1px solid rgba(245,240,227,0.06);">
            <div class="text-[56px] md:text-[64px] font-black text-[var(--red)] opacity-15 leading-none">{s.num}</div>
            <div>
              <h2 class="text-[28px] md:text-[40px] font-black uppercase leading-none mb-3">{s.title}</h2>
              <p class="text-[10px] font-black tracking-[3px] uppercase text-[var(--red)] mb-6">{s.tagline}</p>
              <p class="text-[14px] leading-[1.8] mb-8" style="color: rgba(245,240,227,0.45); font-family: Georgia, serif; max-width: 580px;">{s.desc}</p>
              <ul class="flex flex-col gap-3 mb-8">
                {s.bullets.map(b => (
                  <li class="flex items-center gap-3 text-[11px] font-black tracking-[1px] uppercase" style="color: rgba(245,240,227,0.55);">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--red)] flex-shrink-0"></span>
                    {b}
                  </li>
                ))}
              </ul>
              <a href="/contact" class="btn-press inline-flex items-center gap-3 px-7 py-3.5 bg-[var(--red)] text-white text-[10px] font-black tracking-[3px] uppercase no-underline transition-all duration-300 hover:-translate-y-0.5" style="box-shadow: 0 0 30px rgba(192,57,43,0.25);">
                Get Started →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
