---
import ContactForm from './ContactForm.tsx';
---
<section class="relative overflow-hidden py-24 md:py-32" style="border-top: 1px solid var(--border-red); background: radial-gradient(ellipse 70% 50% at 100% 100%, rgba(192,57,43,0.08) 0%, transparent 60%), #080808;">

  <div class="relative z-10 max-w-[1300px] mx-auto px-6 md:px-12">

    <!-- Section label -->
    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="text-[9px] font-black tracking-[5px] uppercase text-[var(--red)]">Get In Touch</span>
      <div class="flex-1 h-px" style="background: rgba(192,57,43,0.2);"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- LEFT: Context -->
      <div class="reveal">
        <h2 class="font-black uppercase leading-[0.85] mb-8" style="font-size: clamp(40px, 5.5vw, 72px); letter-spacing: -2px;">
          Ready to<br>
          <span class="text-[var(--red)]">Hustle</span><br>
          <span style="-webkit-text-stroke: 1.5px rgba(245,240,227,0.5); color: transparent;">Smarter?</span>
        </h2>

        <p class="text-[14px] leading-[1.8] mb-10" style="color: rgba(245,240,227,0.4); font-family: Georgia, serif; max-width: 400px;">
          Tell us about your business. We'll review your submission and reach out within 24 hours to schedule a free discovery call — no commitment, no pressure.
        </p>

        <div class="flex flex-col gap-4">
          {[
            'Free 30-min discovery call',
            'Response within 24 hours',
            'No commitment required',
          ].map(item => (
            <div class="flex items-center gap-4 text-[10px] font-black tracking-[2px] uppercase" style="color: rgba(245,240,227,0.4);">
              <div class="w-5 h-5 border border-[var(--red)] flex items-center justify-center flex-shrink-0">
                <div class="w-1.5 h-1.5 bg-[var(--red)] rounded-full"></div>
              </div>
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- RIGHT: Form -->
      <div class="reveal reveal-delay-2 p-8 md:p-10" style="border: 1px solid rgba(245,240,227,0.06); background: rgba(245,240,227,0.015);">
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>
