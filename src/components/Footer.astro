      <div>
        <span class="text-[13px] font-black tracking-[4px] uppercase text-[var(--cream)]">H.U.S.T.L.E</span>
        <span class="text-[9px] font-bold tracking-[3px] uppercase text-[var(--red)] block mt-0.5">Consulting LLC</span>
